# --- Server ---
PORT=4000
DATABASE_URL=postgresql://postgres:CHANGEME@localhost:5432/agapai
ADMIN_KEY=change-this-admin-key
TOKEN_SECRET=change-this-random-secret
SMS_ENABLED=true

# --- eGov SSO ---
SSO_BASE=https://hackathon-sso.e.gov.ph
SSO_PARTNER_CODE=
SSO_PARTNER_SECRET=

# --- eVerify ---
EVERIFY_BASE=https://hackathon-everify-api.e.gov.ph
EVERIFY_CLIENT_ID=
EVERIFY_CLIENT_SECRET=
# Face Liveness edit-unlock and record-recovery match the live face against the
# account's National ID (name + birth date) via eVerify /api/query. Set to
# "off" only for demos without eVerify credentials — liveness alone cannot tell
# which person is in front of the camera.
EVERIFY_IDENTITY_MATCH=on

# --- eMessage ---
EMESSAGE_BASE=https://ws-message.e.gov.ph
EMESSAGE_TOKEN=

# --- Face Liveness (eGov) ---
# Anti-spoof "live person" check, run after eVerify at registration, and used
# as the master key to recover consultation records on a new phone.
# NOTE: the REST API is the `-api` host. The bare hackathon-face-liveness.e.gov.ph
# host serves the liveness *web app* (returns HTML), not JSON.
FACE_LIVENESS_BASE=https://hackathon-face-liveness-api.e.gov.ph
FACE_LIVENESS_API_KEY=

# --- At-rest encryption ---
# Decrypts the separate encrypted patient PII store. Keep this secret; whoever
# holds it can decrypt every patient's full record.
PII_ENCRYPTION_KEY=ZIytXzrLVvowfQUVNCESIjabomRluQPh
# Wraps escrowed patient consultation keys (defaults to TOKEN_SECRET if unset).
KEY_ESCROW_SECRET=

# --- eGov AI (fallback for non-health questions) ---
EGOVAI_BASE=https://egov-ai-core-ws.oueg.info
EGOVAI_ACCESS_CODE=

# --- Gemini (primary AI assistant engine) ---
# Free key: https://aistudio.google.com/apikey — leave blank to use the
# curated healthKb + eGov AI fallback chain instead.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
# Voice assistant (Gemini Live). Only the native-audio model answers
# bidiGenerateContent on current keys — the *-live-* ids return 404.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025
# Neural text-to-speech for "read aloud" (assistant replies, records). Makes the
# spoken voice sound human instead of the device's robotic synthesizer. Falls
# back to on-device speech if unset/unavailable. Voice is a Gemini prebuilt
# voice name (e.g. Sulafat, Kore, Aoede, Achird).
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Sulafat
