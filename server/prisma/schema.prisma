generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  PHARMACIST
}

enum MedSource {
  SELF
  DOCTOR
  PHARMACIST
}

model User {
  id                 String   @id @default(cuid())
  egovUniqid         String?
  role               Role     @default(PATIENT)
  firstName          String
  lastName           String
  middleName         String?
  suffix             String?
  birthDate          String?
  gender             String?
  /**
   * Free-form, e.g. "he/him", "she/her", "they/them". Drives how the AI addresses them.
   */
  pronouns           String?
  mobile             String?
  bloodType          String?
  allergies          String   @default("[]")
  conditions         String   @default("[]")
  emergencyName      String?
  emergencyPhone     String?
  prcLicense         String?
  verified           Boolean  @default(false)
  everified          Boolean  @default(false)
  /**
   * True once the person has passed the eGov Face Liveness check at least once.
   */
  liveVerified       Boolean  @default(false)
  /**
   * Optional secondary mobile number. eMessage reminders go to `mobile` AND this.
   */
  mobile2            String?
  /**
   * The device that currently "owns" the escrowed key. A new phone that passes
   * Face Liveness recovery takes ownership, and the previous phone is locked out.
   */
  activeDeviceId     String?
  /**
   * Notify the patient (SMS) when a doctor saves a consultation for them.
   */
  notifyPostConsult  Boolean  @default(true)
  /**
   * Notify the patient (SMS) when a pharmacist dispenses medicine for them.
   */
  notifyPostDispense Boolean  @default(true)
  /**
   * This device's public key (NaCl box, base64) for end-to-end follow-up chat.
   * A patient sealing a follow-up thread key to their doctor encrypts it to this
   * key; only the doctor's device holds the matching secret. Rotated per device.
   */
  publicKey          String?
  /**
   * Doctor opt-in: allow patients to open a follow-up CHAT about their most
   * recent consultation with this doctor. Off by default.
   */
  followUpChat       Boolean  @default(false)
  /**
   * Doctor opt-in: allow the patient from the most recent consultation to place
   * a follow-up CALL (WebRTC). Off by default and independent of chat.
   */
  followUpCall       Boolean  @default(false)
  /**
   * Expo push token for this device, so a follow-up call can RING and a new
   * message can notify even when the app is backgrounded or closed. Best-effort;
   * refreshed on sign-in.
   */
  pushToken          String?
  pushPlatform       String?
  /**
   * ActivityKit push-to-start token (iOS 17.2+). Lets the server START a
   * medication Live Activity over APNs 5 minutes before a dose, even when the
   * app is closed. Refreshed by the app whenever ActivityKit rotates it.
   */
  liveActivityToken  String?
  createdAt          DateTime @default(now())

  consultationsAsPatient Consultation[]        @relation("patient")
  consultationsAsDoctor  Consultation[]        @relation("doctor")
  medications            Medication[]
  keyEscrow              KeyEscrow?
  pii                    PatientPII?
  followUpsAsPatient     FollowUpThread[]      @relation("fuPatient")
  followUpsAsDoctor      FollowUpThread[]      @relation("fuDoctor")
  liveActivitySessions   LiveActivitySession[]

  // One National ID resolves to one eVerify uniqid, but the same person may be
  // both a patient (Health ID) and a professional. Uniqueness is per-role so a
  // doctor/pharmacist account no longer blocks that person's own Health ID.
  @@unique([egovUniqid, role])
}

model Consultation {
  id          String    @id @default(cuid())
  patientId   String
  doctorId    String
  date        DateTime
  type        String
  ciphertext  String
  iv          String
  salt        String
  hasVoice    Boolean   @default(false)
  hasRxImage  Boolean   @default(false)
  dispensedAt DateTime?
  createdAt   DateTime  @default(now())

  patient User @relation("patient", fields: [patientId], references: [id])
  doctor  User @relation("doctor", fields: [doctorId], references: [id])
}

model Medication {
  id             String    @id @default(cuid())
  patientId      String
  name           String
  dosage         String
  instructions   String?
  times          String    @default("[]")
  quantity       Int?
  source         MedSource @default(SELF)
  consultationId String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  patient User @relation(fields: [patientId], references: [id])
}

/**
 * Server-side escrow of a patient's consultation encryption key.
 * The key still lives on the patient's phone and inside their Health ID QR, so
 * day-to-day the server only ever stores ciphertext it cannot read. But so a
 * NEW phone can recover past records, the key is also kept here — wrapped with
 * KEY_ESCROW_SECRET (AES-256-GCM) — and released only after the patient passes
 * an eGov Face Liveness check. Face Liveness is therefore the master key: the
 * phone key follows whichever single device most recently proved liveness.
 */
model KeyEscrow {
  userId     String   @id
  wrappedKey String
  iv         String
  tag        String
  keyVersion Int      @default(1)
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * Full registration PII, captured from eVerify (PhilSys) at sign-up and stored
 * encrypted-at-rest (AES-256-GCM) with PII_ENCRYPTION_KEY. Kept apart from the
 * operational User row so the sensitive record can be decrypted on demand by
 * the key holder only.
 */
model PatientPII {
  userId     String   @id
  ciphertext String
  iv         String
  tag        String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * Audit trail of eGov Face Liveness sessions (create + verification result).
 */
model LivenessCheck {
  id        String   @id @default(cuid())
  userId    String?
  token     String   @unique
  purpose   String
  status    String   @default("PENDING")
  score     Float?
  createdAt DateTime @default(now())
}

/**
 * A doctor ⇄ patient follow-up conversation about a past consultation.
 * Follow-ups are end-to-end encrypted the same way consultations are: each
 * thread has a random 256-bit thread key that never reaches the server in the
 * clear. The patient generates it, keeps a copy on their phone, and SEALS it to
 * the doctor's `publicKey` (NaCl box) — `wrappedKey`/`wrapNonce`/`wrapEphemPub`
 * — so only the doctor's device can unwrap it. The server stores ciphertext it
 * can never read.
 * Retention: `expiresAt` is fixed at creation + 7 days. A cron sweep deletes the
 * whole thread (messages + shares cascade) once expired, so a follow-up costs at
 * most a week of storage — the patient re-shares if they need more time.
 */
model FollowUpThread {
  id             String    @id @default(cuid())
  patientId      String
  doctorId       String
  /**
   * The consultation this follow-up is about (the patient's most recent).
   */
  consultationId String?
  wrappedKey     String?
  wrapNonce      String?
  wrapEphemPub   String?
  status         String    @default("OPEN") // OPEN | CLOSED
  createdAt      DateTime  @default(now())
  lastMessageAt  DateTime  @default(now())
  expiresAt      DateTime
  closedAt       DateTime?

  patient  User              @relation("fuPatient", fields: [patientId], references: [id])
  doctor   User              @relation("fuDoctor", fields: [doctorId], references: [id])
  messages FollowUpMessage[]
  shares   FollowUpShare[]

  @@index([doctorId])
  @@index([patientId])
  @@index([expiresAt])
}

/**
 * One end-to-end encrypted follow-up message (encrypted with the thread key).
 */
model FollowUpMessage {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  senderRole String // PATIENT | DOCTOR
  ciphertext String
  iv         String
  salt       String
  createdAt  DateTime @default(now())

  thread FollowUpThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

/**
 * A patient-shared attachment on a follow-up thread — their past consultation
 * transcript/voice note, or their local AI-assistant history — encrypted with
 * the thread key so the doctor can read it for the 7-day window only.
 */
model FollowUpShare {
  id         String   @id @default(cuid())
  threadId   String
  kind       String // CONSULTATION | AI_HISTORY
  label      String?
  ciphertext String
  iv         String
  salt       String
  createdAt  DateTime @default(now())

  thread FollowUpThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model SmsLog {
  id        String   @id @default(cuid())
  patientId String
  dedupeKey String   @unique
  message   String
  status    String
  sentAt    DateTime @default(now())
}

model Metric {
  id     String   @id @default(cuid())
  route  String
  method String
  status Int
  ms     Int
  at     DateTime @default(now())
}

/**
 * One medication Live Activity the server is driving over APNs for a patient.
 * The live-activity cron (minute-accurate) creates a row and push-to-STARTs the
 * activity ~5 minutes before a dose ("upcoming"), then push-UPDATEs it to "due"
 * at the exact dose time, then push-ENDs it once taken or the answer window
 * lapses. `updateToken` is the per-activity APNs token the app reports back
 * after the activity starts, required to target updates/ends at that instance.
 * The unique key dedupes one activity per patient/med/dose/day.
 */
model LiveActivitySession {
  id             String    @id @default(cuid())
  patientId      String
  medicationId   String
  /**
   * Which of the two push-to-start pop-ups this row is:
   * "pre" — the nudge 5 minutes before the dose,
   * "due" — the check-in at the exact dose time.
   * Both use push-to-start so they appear even with the app fully closed.
   */
  kind           String
  /**
   * Manila calendar day of the dose, YYYY-MM-DD, for dedupe.
   */
  doseDate       String
  /**
   * Dose time as minutes-of-day (Manila), for dedupe + timing.
   */
  doseMinutes    Int
  /**
   * ISO-8601 dose datetime echoed to the activity + on "taken".
   */
  scheduledAtISO String
  /**
   * "upcoming" | "due" | "ended".
   */
  phase          String    @default("upcoming")
  /**
   * Per-activity APNs update token (null until the running app reports it).
   */
  updateToken    String?
  taken          Boolean   @default(false)
  startedAt      DateTime  @default(now())
  endedAt        DateTime?

  patient User @relation(fields: [patientId], references: [id])

  @@unique([patientId, medicationId, doseDate, doseMinutes, kind])
  @@index([phase])
}

/**
 * Verbose per-request log for the admin dashboard. Captures sanitized request
 * and response details (headers, body, response body). Sensitive values
 * (Authorization, x-admin-key, passwords) are redacted before storage.
 * Auto-pruned: rows older than 7 days are deleted by the nightly cron.
 */
model RequestLog {
  id          String   @id @default(cuid())
  method      String
  route       String
  /** Full path including query string, e.g. /api/users?page=1 */
  fullPath    String
  status      Int
  ms          Int
  /** Sanitized request headers as JSON */
  reqHeaders  String   @default("{}")
  /** Sanitized request body as JSON (truncated at 10 KB) */
  reqBody     String   @default("{}")
  /** Sanitized response body as JSON (truncated at 10 KB) */
  resBody     String   @default("{}")
  /** IP address of the caller */
  ip          String?
  at          DateTime @default(now())

  @@index([at])
  @@index([method])
  @@index([status])
  @@index([route])
}

/**
 * Cache of medicine name → visual category (pill, capsule, liquid, inhaler,
 * injection, drops, cream, other). Populated by the AI classifier (Gemini
 * Structured Output) or the keyword heuristic, keyed by the normalized name so
 * a medicine is classified once and reused for every user thereafter — no
 * repeat AI calls for names already seen.
 */
model MedicationCategory {
  name        String   @id
  displayName String
  category    String
  source      String   @default("gemini")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
